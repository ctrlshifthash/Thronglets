# ── AI town intelligence (optional) ──────────────────────────────────
# With a key, towns occasionally generate higher-quality conversations,
# story beats and summaries via OpenRouter (each town uses a model
# matching its culture). Without it, deterministic local templates are
# used — the simulation works identically either way.
# Put the real key in .env.local (gitignored), not here.
OPENROUTER_API_KEY=

# ── Realtime presence server (optional — shows "N watching") ────────
NEXT_PUBLIC_REALTIME_URL=http://localhost:3001
REALTIME_PORT=3001

# ── Database (SQLite via node:sqlite, requires Node >= 23) ───────────
DATABASE_PATH=./data/emergence.db

# ── Token-gated rewards (optional, server-side) ──────────────────────
# Set these in your host's environment (e.g. Railway → Variables), never
# in code or a committed file. Only the App ID is public.
#
# Privy (Solana wallet connect). App ID ships to the client; the secret
# is server-only and verifies wallets before any payout.
NEXT_PUBLIC_PRIVY_APP_ID=
PRIVY_APP_SECRET=
# The wallet rewards are paid FROM (base58 secret key). Keep only a small
# buffer in it — total payout can never exceed its balance. Read at runtime.
PAYOUT_WALLET_SECRET=
# Solana RPC for reading $THRONG balances + sending payouts (paid RPC best).
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
# Devnet RPC, used only when SOLANA_CLUSTER=devnet (for testing payouts).
SOLANA_DEVNET_RPC_URL=https://api.devnet.solana.com
#
# ── Payout controls (Stage 2). Defaults are SAFE: payouts are OFF until
# REWARDS_ENABLED=true, and the cluster defaults to mainnet-beta. ───────
# Master switch — must be "true" for any payout to move. Default: off.
REWARDS_ENABLED=false
# Which chain to pay on. "mainnet-beta" (real) or "devnet" (test).
SOLANA_CLUSTER=mainnet-beta
# The whole daily reward budget, in SOL. This is your hard daily ceiling —
# split across all eligible groves by coins × holding multiplier.
DAILY_POOL_SOL=0.02
# Don't send claims smaller than this (avoids dust + fee waste).
MIN_CLAIM_SOL=0.002
# Ceiling on a single claim (defaults to the daily pool if unset).
PER_CLAIM_CAP_SOL=0.02
